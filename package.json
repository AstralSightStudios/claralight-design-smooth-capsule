{
  "name": "@claralight-design/smooth-capsule",
  "version": "0.1.0",
  "description": "A React smooth capsule glass mask component.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./smooth-capsule.css": "./dist/smooth-capsule.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc && node -e \"const fs=require('node:fs');fs.mkdirSync('dist',{recursive:true});fs.copyFileSync('src/smooth-capsule.css','dist/smooth-capsule.css')\"",
    "dev": "node ./node_modules/vite/bin/vite.js --host 127.0.0.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0"
  },
  "sideEffects": [
    "./dist/smooth-capsule.css"
  ]
}
